{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "next build",
    "start": "next start -p $PORT",
    "lint": "eslint . --max-warnings 0",
    "lint:dev": "eslint .",
    "check-types": "tsc --noEmit",
    "test:e2e": "playwright test --project journeys-chromium",
    "test:e2e:journeys": "playwright test --project journeys-chromium",
    "test:e2e:a11y": "playwright test --project a11y-chromium",
    "test:e2e:journeys:isolated": "PLAYWRIGHT_DB_SLOT=journeys PORT=3001 NEXT_DIST_DIR=.next-e2e-journeys playwright test --project journeys-chromium",
    "test:e2e:a11y:isolated": "PLAYWRIGHT_DB_SLOT=a11y PORT=3002 NEXT_DIST_DIR=.next-e2e-a11y playwright test --project a11y-chromium",
    "test:e2e:parallel": "sh -c 'pnpm test:e2e:journeys:isolated & pnpm test:e2e:a11y:isolated & wait'",
    "test:e2e:smoke": "playwright test --project journeys-chromium -- e2e/smoke",
    "test": "node -e \"if(!process.env.RUN_E2E){console.log('skip test (web)');process.exit(0)}else{process.exit(1)}\" || playwright test",
    "prettier": "prettier . --write",
    "lint:staged": "pnpm exec lint-staged -c .lintstagedrc.cjs --relative --cwd ."
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.0",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@mui/material-nextjs": "^7.3.5",
    "@mui/x-date-pickers": "^8.27.0",
    "@prisma/client": "^5.22.0",
    "@repo/application": "workspace:*",
    "@repo/crypto": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/domain": "workspace:*",
    "@repo/form": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/view-models": "workspace:*",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.2",
    "nodemailer": "^7.0.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.45.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "22.15.3",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "19.2.5",
    "@types/react-dom": "19.2.3",
    "dotenv": "^16.5.0",
    "eslint": "^9.36.0",
    "typescript": "5.9.3"
  }
}
